# Deny all direct web access to uploaded files.
# Vault/request files are served only through the authenticated
# /api/v1/.../download endpoints (server-side readfile), never directly.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
