# HR Budget System - Environment Configuration

# Application Settings
APP_NAME="HR Budget System"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://hr_budget.test
APP_TIMEZONE=Asia/Bangkok

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=hr_budget
DB_USERNAME=root
DB_PASSWORD=

# Session Configuration
SESSION_LIFETIME=120
SESSION_SECURE=false

# Vite Development Server (legacy assets)
VITE_DEV_SERVER=http://localhost:5173

# JWT Auth (REST API)
# Generate with: php -r "echo bin2hex(random_bytes(32));"
JWT_SECRET=replace-with-random-64-hex-chars
JWT_TTL=3600

# CORS — comma-separated list of allowed origins for /api/*
CORS_ORIGINS=http://localhost:5174
