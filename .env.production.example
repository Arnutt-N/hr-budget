# ============================================================
#  HR Budget — Production .env  (deploy: topzlab.com/hr-budget)
#  วิธีใช้: เปลี่ยนชื่อไฟล์นี้เป็น  .env  (ตัด .production.example ออก)
#          แล้วเติมค่าจริงในช่อง __...__  โดยเฉพาะ DB_* และ JWT_SECRET
#  เคล็ดลับ: ถ้ามี .env ในเครื่อง Laragon ที่ใช้ได้อยู่แล้ว ก๊อปมาแล้ว
#           แก้แค่ DB_*, APP_URL, JWT_SECRET, *_SECURE ก็พอ (คีย์ครบแน่นอน)
# ============================================================

# ---------- App ----------
APP_NAME="HR Budget"
APP_ENV=production
APP_DEBUG=false                 # ตั้ง true "ชั่วคราว" ถ้าต้องการเห็น error บนหน้าจอ แล้วเปลี่ยนกลับ false
APP_URL=https://topzlab.com/hr-budget/public
APP_TIMEZONE=Asia/Bangkok

# ---------- Database (เอาค่าจาก Plesk → Databases) ----------
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=__ชื่อ_database__
DB_USERNAME=__db_user__
DB_PASSWORD=__db_password__

# ---------- API / JWT (สำคัญต่อการ login — ห้ามเว้นว่าง) ----------
# สร้าง secret สุ่มยาว >= 32 ตัวอักษร เช่น: openssl rand -hex 32
# หรือสุ่มจาก https://www.random.org/strings/  (เลือก 64 ตัว, hex)
JWT_SECRET=__ใส่_random_secret_ยาวๆ_ที่นี่__
JWT_TTL=3600
CORS_ORIGINS=https://topzlab.com

# ---------- Session / Cookie (เว็บเป็น HTTPS → true) ----------
SESSION_LIFETIME=120
SESSION_SECURE=true
COOKIE_SECURE=true

# ---------- ThaID (ยังไม่ใช้ → ปล่อย mock ไว้) ----------
THAID_MOCK=true
